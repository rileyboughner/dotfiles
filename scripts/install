#!/usr/bin/env nix-shell
#!nix-shell -i bash -p git gum


USER_HOME=$(eval echo ~"$USER")

# create a var for the dotfiles repo https://github.com/rileyboughner/dotfiles.git
DOTFILES_REPO="https://github.com/rileyboughner/dotfiles.git"
# create a var for the wallpaper repo https://github.com/rileyboughner/wallpapers.git
WALLPAPERS_REPO="https://github.com/rileyboughner/wallpapers.git"

# clone the dotfiles to ~/.dotfiles
git clone "$DOTFILES_REPO" "$USER_HOME/.dotfiles"
# clone the wallpapers to ~/.wallpapers
git clone "$WALLPAPERS_REPO" "$USER_HOME/.wallpapers"

# remove .config file and create fresh .config
rm -rf "$USER_HOME/.config"
mkdir -p "$USER_HOME/.config"

# run this command to link dotfiles and config file ln -s /home/rileyboughner/.dotfiles/dotfiles/* ~/.config
ln -s $USER_HOME/.dotfiles/dotfiles/* "$USER_HOME/.config/"
# link .zshrc from ~/.dotfiles/dotfiles/zsh/.zshrc
ln -s "$USER_HOME/.dotfiles/dotfiles/zsh/.zshrc" "$USER_HOME/.zshrc"


# select the system to build
SYSTEMS_PATH="$USER_HOME/.dotfiles/nixos/hosts"
SYSTEMS=$(ls -d "$SYSTEMS_PATH"/*/ | xargs -n 1 basename)

SELECTED_SYSTEM=$(echo "$SYSTEMS" | gum choose)

if [ -z "$SELECTED_SYSTEM" ]; then
  echo "No system selected. Exiting."
  exit 1
fi

sudo nixos-rebuild switch --flake ".#$SELECTED_SYSTEM"

#set the theme and wallpaper
cp $USER_HOME/.wallpapers/fogsmoke/a_building_with_trees_in_the_background.jpg $USER_HOME/.wallpaper
hyprctl hyprpaper preload "$USER_HOME/.wallpaper"
hyprctl hyprpaper wallpaper ",$USER_HOME/.wallpaper"
$USER_HOME/.dotfiles/scripts/set-theme-from-wallpaper

